generator client {
  // Prisma generates the typed TypeScript client consumed from
  // packages/database/src/index.ts.
  provider = "prisma-client-js"
}

datasource db {
  // SQLite keeps this desktop/local tool easy to run without a separate DB
  // server. Production multi-user deployments would usually switch providers.
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Settings is treated like a singleton table by the API: routes read the first
// row and create it on demand when the database is empty.
model Settings {
  id                String   @id @default(cuid())
  authMode          String   @default("GEMINI")
  textProvider      String   @default("GEMINI")
  imageProvider     String   @default("GEMINI")
  geminiApiKey      String?
  vertexProjectId   String?
  vertexClientEmail String?
  vertexPrivateKey  String?
  textModel         String   @default("gemini-1.5-pro")
  imageModel        String   @default("imagen-3.0-generate-001")
  textBaseUrl       String?
  imageBaseUrl      String?
  textApiKey        String?
  imageApiKey       String?
  maxConcurrency    Int      @default(3)
  globalSeed        Int?     // To hold the selected golden seed
  updatedAt         DateTime @updatedAt
}

// Project stores the editable resource tree as JSON because the tree shape is
// nested and changes frequently. The shared IResourceNode type documents that
// JSON shape on the TypeScript side.
model Project {
  id          String   @id @default(cuid())
  name        String   @default("Untitled Project")
  treeData    String   
  isGenerating Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// GoldenSeed records reusable seeds discovered during generation. The current
// UI ships with sample seeds, but this model is ready for persisted history.
model GoldenSeed {
  id          String   @id @default(cuid())
  seed        Int      @unique
  name        String
  description String?
  imageUrl    String?  // Reference to the image that produced this good seed
  createdAt   DateTime @default(now())
}
